rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AGROSALSO SECURITY RULES - HARDENED V3 (Bulletproof)
     */

    function isAdmin() {
      return request.auth != null;
    }

    // Catalogul de produse și resursele auxiliare sunt publice pentru citire
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Securizare statistici: Vizitatorii pot doar incrementa strict contorul
    match /siteMetadata/stats {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visitCount']) 
                   && request.resource.data.visitCount is int 
                   && request.resource.data.visitCount > resource.data.visitCount;
    }

    // Lead-urile sunt strict private. Crearea este permisă oricui.
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}