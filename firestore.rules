rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AGROSALSO SECURITY RULES
     * Ensures public catalog access and admin-only management.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Publicly readable collections (Catalog)
    // admin-only writes (using isSignedIn for prototype simplicity)
    
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Public submission for inquiries, Admin-only read/manage
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }
  }
}