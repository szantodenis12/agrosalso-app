rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths=**} {
      // Permite citirea publică a imaginilor produselor
      allow read: if true;
      
      // Permite scrierea (upload/delete) doar utilizatorilor autentificați
      allow write: if request.auth != null;
    }
  }
}