rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Imaginile sunt publice pentru vizualizare
    // Scrierea este permisă doar administratorilor în folderele specifice
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Fallback pentru restul fișierelor
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}