
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Regulile au fost simplificate pentru a permite upload-ul oricărui utilizator autentificat (Admin)
    // Sincronizare reguli forțată prin comentariu: 1772656800
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
