
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents an agricultural machine or equipment.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "brand": { "type": "string" },
        "brandSlug": { "type": "string" },
        "category": { "type": "string" },
        "shortDescription": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "priceOnRequest": { "type": "boolean" },
        "currency": { "type": "string" },
        "mainImage": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "specifications": { "type": "object" },
        "inStock": { "type": "boolean" },
        "stockQuantity": { "type": "number" },
        "isNew": { "type": "boolean" },
        "isFeatured": { "type": "boolean" },
        "isOnSale": { "type": "boolean" },
        "salePercent": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "slug", "brand", "category", "shortDescription", "price", "mainImage"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "icon": { "type": "string" },
        "description": { "type": "string" },
        "productCount": { "type": "number" },
        "order": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "slug"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "read", "replied"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "phone", "message", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Catalog of agricultural machinery."
    },
    "categories/{categoryId}": {
      "schema": { "$ref": "#/backend/entities/Category" },
      "description": "Product categories for classification."
    },
    "inquiries/{inquiryId}": {
      "schema": { "$ref": "#/backend/entities/Inquiry" },
      "description": "Customer lead submissions."
    }
  }
}
